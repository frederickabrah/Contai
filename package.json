  },
  "homepage": "https://github.com/frederickabrah/Contai#readme",
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "dotenv": "^16.4.5",
    "fast-xml-parser": "^5.5.9",
    "node-fetch": "^3.3.2"
  },
  "engines": {
